### 0. Login (get token)
POST {{host}}/api/auth/login
Content-Type: application/json

{
    "username": "admin",
    "password": "admin"
}

### 1. Get All DBlockers
GET {{host}}/api/dblockers
Authorization: Bearer {{token}}

### 2. Get DBlocker by ID
GET {{host}}/api/dblockers/7
Authorization: Bearer {{token}}


##########################################
### 3a. Update DBlocker Default Config
#### blocker no 2, 6, 7, 8
PUT {{host}}/api/dblockers/default
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "id": 8,
    "config": [
        {"signal_ctrl": true, "signal_gps": false},
        {"signal_ctrl": true, "signal_gps": false},
        {"signal_ctrl": true, "signal_gps": false},
        {"signal_ctrl": false, "signal_gps": false},
        {"signal_ctrl": false, "signal_gps": false},
        {"signal_ctrl": false, "signal_gps": false}
    ]
}

