# Copy this file to .env.prod on your production server
# cp .env.prod.example .env.prod

# App
APP_PORT=8080
GIN_MODE=release

# MQTT internal (container-to-container)
MQTT_BROKER=tcp://mosquitto:1883
MQTT_USERNAME=DBL0KER
MQTT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MQTT_PUBLIC_PORT=1883

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=scm
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=dblocker-db
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_SECRET
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# API Key (shared between dblocker-app and dblocker-assist-app)
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_API_KEY

# Vision server
VISION_PORT=8090

# Camera credentials (shared across all cameras)
CAMERA_USERNAME=admin
CAMERA_PASSWORD=CHANGE_ME_CAMERA_PASSWORD

# Device 1
DEVICE_1_NAME=Device 1
DEVICE_1_NORMAL_HOST=10.88.5.100
DEVICE_1_THERMAL_HOST=10.88.5.101
DEVICE_1_PANTILT_HOST=10.88.5.100
DEVICE_1_ZOOM_HOST=10.88.5.101

# Device 2
DEVICE_2_NAME=Device 2
DEVICE_2_NORMAL_HOST=10.88.5.102
DEVICE_2_THERMAL_HOST=10.88.5.103
DEVICE_2_PANTILT_HOST=10.88.5.102
DEVICE_2_ZOOM_HOST=10.88.5.103

# Recording output directory
# The directory on THIS machine where recorded videos will be saved.
# The container always writes to /recordings internally; this mounts a host path there.
#
# IMPORTANT: The directory must already exist on the host before running docker compose.
#   mkdir -p /path/to/your/directory
#
# Examples:
#   Relative to project folder (auto-created by Docker, easiest for dev):
#     RECORD_DIR_HOST=./recordings
#
#   Absolute path on main disk:
#     RECORD_DIR_HOST=/home/user/Videos/recordings
#
#   New/extra disk (find the mount point with: lsblk -o NAME,MOUNTPOINT):
#     RECORD_DIR_HOST=/mnt/disk2/recordings
#     RECORD_DIR_HOST=/media/user/MyDisk/recordings
#
#   NAS or network share (must be mounted on host first):
#     RECORD_DIR_HOST=/mnt/nas/camera-recordings
#
RECORD_DIR_HOST=./recordings
