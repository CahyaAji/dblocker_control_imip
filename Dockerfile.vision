FROM golang:1.25-alpine AS builder

WORKDIR /app

ARG TARGETOS
ARG TARGETARCH

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} go build -o /app/vision ./cmd/vision

FROM alpine:3.21

RUN apk add --no-cache ffmpeg ca-certificates

WORKDIR /app
COPY --from=builder /app/vision /app/vision

EXPOSE 8090
ENTRYPOINT ["/app/vision"]
